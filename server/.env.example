# Image generation: Imaginer (Mirava), model gpt-image-2.
# MOCK_AI=true: HANYA generate gambar yang di-mock (nol kredit).
# Set false untuk generate sungguhan juga.
MOCK_AI=true
IMAGINER_API_KEY=
# Decoration analysis: kie.ai (gemini-2.5-flash, OpenAI-compatible chat
# completions, sangat murah). Selalu pakai API asli — tidak ikut MOCK_AI.
KIE_API_KEY=
API_PORT=4489
GENERATION_DAILY_CAP=20

# Neon Postgres (pooled connection string, from Vercel Storage / Neon dashboard)
DATABASE_URL=
# Vercel Blob (images + reference uploads), from Vercel Storage
BLOB_READ_WRITE_TOKEN=

# Auth: JWT signing secret — a long random string, DIFFERENT from the Google
# client ID below and never exposed to the frontend. Generate one with
# `openssl rand -hex 32`. Anyone who knows this value can forge login tokens
# for any user, so treat it like a password.
AUTH_JWT_SECRET=
# Google Sign-In OAuth Client ID (Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth client ID -> Web application). This one IS meant to be
# public — Vite exposes VITE_-prefixed vars to the browser bundle.
VITE_GOOGLE_CLIENT_ID=
