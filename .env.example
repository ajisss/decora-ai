# Single key covers both image generation (gpt-image-2, async jobs API) and
# decoration analysis (gemini-2.5-flash, OpenAI-compatible chat completions).
# MOCK_AI=true: HANYA generate gambar yang di-mock (nol kredit).
# Analisis selalu pakai kie.ai asli (gemini-2.5-flash, sangat murah).
# Set false untuk generate sungguhan juga.
MOCK_AI=true
KIE_API_KEY=
API_PORT=4489
GENERATION_DAILY_CAP=20
# Only needed for reference-guided (image-to-image) generation: a publicly
# reachable base URL (deployment or ngrok tunnel) so kie.ai can fetch the
# reference image. Leave unset in local dev — reference images are then
# ignored and generation falls back to text-to-image.
PUBLIC_BASE_URL=
