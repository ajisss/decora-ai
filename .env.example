# Image generation: Imaginer (Mirava), model gpt-image-2.
# MOCK_AI=true: HANYA generate gambar yang di-mock (nol kredit).
# Set false untuk generate sungguhan juga.
MOCK_AI=true
IMAGINER_API_KEY=
# Decoration analysis: kie.ai (gemini-2.5-flash, OpenAI-compatible chat
# completions, sangat murah). Selalu pakai API asli — tidak ikut MOCK_AI.
KIE_API_KEY=
API_PORT=4489
GENERATION_DAILY_CAP=20
# Auth: JWT signing secret (any long random string) + Google Sign-In OAuth
# Client ID (Google Cloud Console -> APIs & Services -> Credentials -> OAuth
# client ID -> Web application). One value used by both the frontend bundle
# (Vite only exposes VITE_-prefixed vars to the client) and the backend
# token verifier.
AUTH_JWT_SECRET=
VITE_GOOGLE_CLIENT_ID=
